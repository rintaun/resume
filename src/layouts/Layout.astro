---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Matthew Lanigan | Senior Software Engineer", 
  description = "Professional resume and portfolio of Matthew Lanigan, a Senior Software Engineer specializing in full-stack web application development, microservices, and system design."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Theme Initialization Script to Prevent Flashing -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        // Default to dark theme as it matches the premium aesthetic
        return 'dark';
      })();
      
      if (theme === 'light') {
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.remove('light');
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
