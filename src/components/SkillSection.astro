---
import { skillCategories } from '../data/resume';
---

<div class="skills-container glass-panel">
  <div class="web-skills">
    <div class="skills-header">
      <h3 class="section-title">Skills & Expertise</h3>
      <p class="skills-filter-instruction no-print">Click on any skill to highlight matching work experience.</p>
    </div>
    
    <div class="categories-grid">
      {skillCategories.map(category => (
        <div class="category-block">
          <h4 class="category-title">{category.name}</h4>
          <div class="skills-list">
            {category.skills.map(skill => (
              <button 
                class="badge skill-badge" 
                data-skill={skill.toLowerCase()}
                title={`Filter experience by ${skill}`}
              >
                {skill}
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>
    
    <div class="filter-controls no-print" id="filter-controls" style="display: none;">
      <span class="active-filter-text">Filtering by: <strong id="active-skill-name"></strong></span>
      <button class="clear-filter-btn" id="clear-filter">
        Clear Filter
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <!-- Print-only static version of skills to guarantee beautiful PDFs -->
  <div class="skills-print-container" style="display: none;">
    {skillCategories.map(category => (
      <div class="skills-print-category">
        <strong>{category.name}:</strong> {category.skills.join(', ')}
      </div>
    ))}
  </div>
</div>

<style>
  .skills-container {
    margin-bottom: 2rem;
  }

  .skills-header {
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .skills-filter-instruction {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .category-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .category-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-badge {
    cursor: pointer;
    user-select: none;
  }

  .skill-badge:hover {
    border-color: var(--accent-primary);
    color: var(--text-primary);
    background: var(--accent-primary-glow);
    transform: translateY(-1px);
  }

  .skill-badge.active-filter {
    background: var(--accent-primary);
    color: #ffffff;
    border-color: var(--accent-primary);
    box-shadow: 0 0 12px var(--accent-primary-glow);
  }

  /* Filter indicator controls */
  .filter-controls {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--surface-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    animation: fadeIn 0.2s ease-out;
  }

  .active-filter-text {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .active-filter-text strong {
    color: var(--accent-primary);
    font-weight: 600;
  }

  .clear-filter-btn {
    background: var(--badge-bg);
    color: var(--badge-text);
    border: 1px solid var(--badge-border);
    padding: 0.35rem 0.75rem;
    border-radius: var(--border-radius-sm);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    transition: all var(--transition-fast);
  }

  .clear-filter-btn:hover {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.2);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  // Setup click listeners for skill badges to filter experience cards
  document.addEventListener('DOMContentLoaded', () => {
    const badges = document.querySelectorAll('.skill-badge');
    const clearBtn = document.getElementById('clear-filter');
    const controls = document.getElementById('filter-controls');
    const activeText = document.getElementById('active-skill-name');
    let currentFilter = '';

    const filterExperience = (skill) => {
      currentFilter = skill;
      
      // Update UI active states
      badges.forEach(b => {
        if (b.getAttribute('data-skill') === skill) {
          b.classList.add('active-filter');
        } else {
          b.classList.remove('active-filter');
        }
      });

      // Update control panel
      if (controls && activeText) {
        const readableName = Array.from(badges).find(b => b.getAttribute('data-skill') === skill)?.textContent || skill;
        activeText.textContent = readableName;
        controls.style.display = 'flex';
      }

      // Dispatch custom event to experience cards
      const event = new CustomEvent('filter-experience', { detail: { skill } });
      document.dispatchEvent(event);
    };

    const clearFilter = () => {
      currentFilter = '';
      
      badges.forEach(b => b.classList.remove('active-filter'));
      
      if (controls) {
        controls.style.display = 'none';
      }

      // Dispatch reset event
      const event = new CustomEvent('filter-experience', { detail: { skill: '' } });
      document.dispatchEvent(event);
    };

    badges.forEach(badge => {
      badge.addEventListener('click', () => {
        const skill = badge.getAttribute('data-skill');
        if (currentFilter === skill) {
          clearFilter();
        } else {
          filterExperience(skill);
        }
      });
    });

    clearBtn?.addEventListener('click', clearFilter);
  });
</script>
