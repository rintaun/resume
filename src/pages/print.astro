---
import {
  contactInfo,
  objective,
  workExperience,
  educationHistory,
  skillCategories,
} from "../data/resume";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Matthew Lanigan - Resume (Printable)</title>
    <meta name="robots" content="noindex" />

    <!-- Google Fonts for Print Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="no-print print-banner">
      <div class="banner-content">
        <button onclick="window.print()" class="banner-print-btn">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="6 9 6 2 18 2 18 9"></polyline><path
              d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"
            ></path><rect x="6" y="14" width="12" height="8"></rect></svg
          >
          Print / Save PDF
        </button>
      </div>
    </div>

    <div class="resume-wrapper">
      <!-- PAGE 1 -->
    <div class="resume-page">
      <!-- Centered Compact Header -->
      <header class="resume-header">
        <h1>{contactInfo.name}</h1>
        <p class="title">{contactInfo.title}</p>

        <div class="contact-line">
          <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
          <span class="divider">•</span>
          <a href={`tel:${contactInfo.phone.replace(/[^0-9+]/g, "")}`}
            >{contactInfo.phone}</a
          >
          <span class="divider">•</span>
          <span>{contactInfo.location}</span>
        </div>

        <div class="links-line">
          <a href={contactInfo.github} target="_blank" rel="noopener noreferrer"
            >github.com/rintaun</a
          >
          <span class="divider">•</span>
          <a
            href={contactInfo.linkedin}
            target="_blank"
            rel="noopener noreferrer">linkedin.com/in/matthewlanigan</a
          >
          <span class="divider">•</span>
          <a
            href={contactInfo.website}
            target="_blank"
            rel="noopener noreferrer">rintaun.dev</a
          >
        </div>
      </header>

      <!-- Professional Summary -->
      <section class="resume-section">
        <h2>Professional Summary</h2>
        <p class="summary-text">{objective}</p>
      </section>

      <!-- Skills Section -->
      <section class="resume-section">
        <h2>Skills & Expertise</h2>
        <div class="skills-grid">
          {
            skillCategories.map((category) => (
              <div class="skills-row">
                <span class="category-name">{category.name}:</span>
                <span class="skills-list">{category.skills.join(", ")}</span>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Experience Section (First Part) -->
      <section class="resume-section">
        <h2>Work Experience</h2>

        <!-- Render only the two most recent experiences on Page 1 -->
        {
          workExperience.slice(0, 2).map((exp) => (
            <div class="job-entry">
              <div class="job-header">
                <div class="job-title-company">
                  <span class="job-role">{exp.role}</span>
                  <span class="job-company">— {exp.company}</span>
                  {exp.location && (
                    <span class="job-location">({exp.location})</span>
                  )}
                </div>
                <span class="job-dates">
                  {exp.startDate} – {exp.endDate}
                </span>
              </div>

              <ul class="job-bullets">
                {exp.bullets.map((bullet) => (
                  <li>
                    {bullet.text}
                    {bullet.tech && (
                      <span class="tech-inline">
                        {" "}
                        ({bullet.tech.join(", ")})
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </section>
    </div>

    <!-- PAGE 2 -->
    <div class="resume-page page-break">
      <!-- Experience Section (Remaining Part) -->
      <section class="resume-section" style="margin-top: 0;">
        <!-- Remaining experiences on Page 2 -->
        {
          workExperience.slice(2).map((exp) => (
            <div class="job-entry">
              <div class="job-header">
                <div class="job-title-company">
                  <span class="job-role">{exp.role}</span>
                  <span class="job-company">— {exp.company}</span>
                  {exp.location && (
                    <span class="job-location">({exp.location})</span>
                  )}
                </div>
                <span class="job-dates">
                  {exp.startDate} – {exp.endDate}
                </span>
              </div>

              <ul class="job-bullets">
                {exp.bullets.map((bullet) => (
                  <li>
                    {bullet.text}
                    {bullet.tech && (
                      <span class="tech-inline">
                        {" "}
                        ({bullet.tech.join(", ")})
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </section>

      <!-- Education Section -->
      <section class="resume-section">
        <h2>Education</h2>
        <div class="education-container">
          {
            educationHistory.map((edu) => (
              <div class="edu-entry">
                <div class="edu-header">
                  <div class="edu-title-inst">
                    <span class="edu-degree">{edu.degree}</span>
                    <span class="edu-institution">— {edu.institution}</span>
                    <span class="edu-location">({edu.location})</span>
                  </div>
                  <span class="edu-date">{edu.date}</span>
                </div>
                <p class="edu-field">{edu.field}</p>
                {edu.details && (
                  <ul class="edu-bullets">
                    {edu.details.map((detail) => (
                      <li>{detail}</li>
                    ))}
                  </ul>
                )}
              </div>
            ))
          }
        </div>
      </section>
    </div>
    </div>
  </body>
</html>

<style>
  /* Base styles for the page preview layout */
  :root {
    --text-color: #2c3e50;
    --text-dark: #1a202c;
    --text-light: #4a5568;
    --border-color: #e2e8f0;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background-color: #f0f2f5;
    color: var(--text-dark);
    font-family:
      "Inter",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      sans-serif;
    line-height: 1.4;
    padding-bottom: 3rem;
    overflow-x: hidden;
    width: 100%;
  }

  /* Preview Banner */
  .print-banner {
    background: #1e293b;
    color: #ffffff;
    padding: 0.8rem 1.5rem;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .banner-content {
    max-width: 8.5in;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }

  .banner-print-btn {
    background: #3b82f6;
    color: white;
    border: none;
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: background 0.15s ease;
  }

  .banner-print-btn:hover {
    background: #2563eb;
  }

  .resume-wrapper {
    width: 100%;
    overflow-x: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 1rem;
    -webkit-overflow-scrolling: touch;
  }

  /* Sheet of paper styles for screen view */
  .resume-page {
    background: #ffffff;
    width: 8.5in;
    height: 11in;
    margin: 2rem 0 0 0;
    flex-shrink: 0;
    padding: 0.6in 0.75in;
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.05),
      0 1px 2px rgba(0, 0, 0, 0.02);
    position: relative;
    overflow: hidden;
  }

  /* Header Styles */
  .resume-header {
    text-align: center;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1.5px solid var(--text-dark);
  }

  .resume-header h1 {
    font-size: 20pt;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-dark);
    margin-bottom: 0.15rem;
  }

  .resume-header p.title {
    font-size: 11.5pt;
    font-weight: 600;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.4rem;
  }

  .contact-line,
  .links-line {
    font-size: 8.5pt;
    color: var(--text-light);
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.15rem;
  }

  .contact-line a,
  .links-line a {
    text-decoration: none;
    color: var(--text-light);
  }

  .contact-line a:hover,
  .links-line a:hover {
    color: var(--text-dark);
    text-decoration: underline;
  }

  .divider {
    color: #cbd5e1;
  }

  /* Sections */
  .resume-section {
    margin-bottom: 1rem;
  }

  .resume-section h2 {
    font-size: 10.5pt;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
    color: var(--text-dark);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.2rem;
    margin-bottom: 0.5rem;
  }

  .summary-text {
    font-size: 9pt;
    color: var(--text-light);
    line-height: 1.45;
    text-align: justify;
  }

  /* Skills Grid */
  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .skills-row {
    display: grid;
    grid-template-columns: 1.6in 1fr;
    font-size: 8.5pt;
    line-height: 1.3;
  }

  .category-name {
    font-weight: 600;
    color: var(--text-dark);
  }

  .skills-list {
    color: var(--text-light);
  }

  /* Job Entries */
  .job-entry {
    margin-bottom: 0.8rem;
  }

  .job-entry:last-of-type {
    margin-bottom: 0;
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.25rem;
  }

  .job-title-company {
    font-size: 9.5pt;
  }

  .job-role {
    font-weight: 700;
    color: var(--text-dark);
  }

  .job-company {
    font-weight: 600;
    color: var(--text-light);
    margin-left: 0.2rem;
  }

  .job-location {
    font-size: 8.5pt;
    color: var(--text-light);
    font-style: italic;
    margin-left: 0.2rem;
  }

  .job-dates {
    font-size: 8.5pt;
    color: var(--text-light);
    font-weight: 500;
  }

  .job-bullets {
    list-style-type: disc;
    margin-left: 0.95rem;
    font-size: 8.5pt;
    color: var(--text-light);
    line-height: 1.35;
  }

  .job-bullets li {
    margin-bottom: 0.15rem;
  }

  .tech-inline {
    font-style: italic;
    color: var(--text-light);
    font-weight: 500;
  }

  /* Education Entries */
  .education-container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .edu-entry {
    line-height: 1.35;
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .edu-title-inst {
    font-size: 9.5pt;
  }

  .edu-degree {
    font-weight: 700;
    color: var(--text-dark);
  }

  .edu-institution {
    font-weight: 600;
    color: var(--text-light);
    margin-left: 0.2rem;
  }

  .edu-location {
    font-size: 8.5pt;
    color: var(--text-light);
    font-style: italic;
    margin-left: 0.2rem;
  }

  .edu-date {
    font-size: 8.5pt;
    color: var(--text-light);
  }

  .edu-field {
    font-size: 8.5pt;
    font-weight: 500;
    color: var(--text-light);
    margin-bottom: 0.15rem;
  }

  .edu-bullets {
    list-style-type: circle;
    margin-left: 0.95rem;
    font-size: 8.5pt;
    color: var(--text-light);
    line-height: 1.35;
  }

  .edu-bullets li {
    margin-bottom: 0.15rem;
  }

  /* Print Specific Overrides */
  @media print {
    body {
      background-color: #ffffff !important;
      padding-bottom: 0 !important;
    }

    .no-print {
      display: none !important;
    }

    .resume-wrapper {
      width: 100% !important;
      overflow: visible !important;
      padding: 0 !important;
      display: block !important;
    }

    .resume-page {
      width: 100% !important;
      height: auto !important;
      min-height: 0 !important;
      margin: 0 !important;
      padding: 0 !important;
      box-shadow: none !important;
      overflow: visible !important;
    }

    .page-break {
      page-break-before: always !important;
      break-before: page !important;
      margin-top: 0.4in !important; /* Standard spacing for second page */
    }

    /* Enforce pure black for print reliability */
    :root {
      --text-dark: #000000;
      --text-light: #222222;
      --border-color: #cccccc;
    }
  }
</style>

<script>
  // Automatically trigger print dialog if ?print=true is present
  document.addEventListener("DOMContentLoaded", () => {
    const params = new URLSearchParams(window.location.search);
    if (params.get("print") === "true") {
      window.print();
    }
  });
</script>
