---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import SkillSection from "../components/SkillSection.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import {
  contactInfo,
  objective,
  workExperience,
  educationHistory,
} from "../data/resume";
---

<Layout>
  <!-- Sleek background elements for web view -->
  <div class="glow-bg no-print"></div>

  <ThemeToggle />

  <main class="container">
    <!-- Header Section -->
    <header class="header-grid glass-panel">
      <div class="header-left">
        <h1>{contactInfo.name}</h1>
        <p class="title">{contactInfo.title}</p>

        <!-- Objective (Web-only short version or intro) -->
        <p class="web-summary no-print">
          Passionate full-stack leader and engineer with 10+ years of experience
          designing high-scale backend services, microservices, and modern
          frontend architectures.
        </p>
      </div>

      <div class="header-right">
        <!-- Contact Grid -->
        <div class="contact-details">
          <div class="contact-item">
            <svg
              class="no-print"
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
            <a href={`tel:${contactInfo.phone.replace(/[^0-9+]/g, "")}`}
              >{contactInfo.phone}</a
            >
          </div>

          <div class="contact-item">
            <svg
              class="no-print"
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path><polyline points="22,6 12,13 2,6"></polyline></svg
            >
            <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
          </div>

          <div class="contact-item">
            <svg
              class="no-print"
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            >
            <span>{contactInfo.location}</span>
          </div>

          <div class="contact-item no-print-links">
            <svg
              class="no-print"
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
              ></path></svg
            >
            <a
              href={contactInfo.github}
              target="_blank"
              rel="noopener noreferrer"
            >
              github.com/rintaun
              <span class="contact-link-arrow no-print">↗</span>
            </a>
          </div>

          <div class="contact-item no-print-links">
            <svg
              class="no-print"
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path><rect x="2" y="9" width="4" height="12"></rect><circle
                cx="4"
                cy="4"
                r="2"></circle></svg
            >
            <a
              href={contactInfo.linkedin}
              target="_blank"
              rel="noopener noreferrer"
            >
              linkedin.com/in/matthewlanigan
              <span class="contact-link-arrow no-print">↗</span>
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Professional Summary -->
    <section class="objective-section glass-panel">
      <h2>Professional Summary</h2>
      <p class="objective-text">{objective}</p>
    </section>

    <!-- Skills Matrix -->
    <section class="skills-section">
      <SkillSection />
    </section>

    <!-- Professional Experience -->
    <section class="experience-section">
      <h2 class="section-title-large">Work Experience</h2>
      <div class="experience-timeline">
        {
          workExperience.map((exp, idx) => (
            <ExperienceCard experience={exp} index={idx} />
          ))
        }
      </div>
    </section>

    <!-- Education Section -->
    <section class="education-section glass-panel">
      <h2>Education</h2>
      <div class="education-list">
        {
          educationHistory.map((edu) => (
            <div class="education-card">
              <div class="education-header">
                <div class="education-title-group">
                  <h3 class="education-degree">{edu.degree}</h3>
                  <span class="education-institution">{edu.institution}</span>
                  <span class="education-location">({edu.location})</span>
                </div>
                <span class="education-date">{edu.date}</span>
              </div>

              <p class="education-field">{edu.field}</p>

              {edu.details && (
                <ul class="education-details">
                  {edu.details.map((detail) => (
                    <li>{detail}</li>
                  ))}
                </ul>
              )}
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Page background glows */
  .glow-bg {
    position: absolute;
    top: 0;
    left: 25%;
    width: 600px;
    height: 600px;
    background: radial-gradient(
      circle,
      rgba(99, 102, 241, 0.06) 0%,
      transparent 70%
    );
    z-index: -10;
    pointer-events: none;
  }

  /* Header CSS */
  .header-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .header-grid {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .header-left {
    flex: 1.2;
  }

  .header-left h1 {
    font-size: 2.5rem;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
    background: linear-gradient(
      135deg,
      var(--text-primary) 30%,
      var(--accent-primary) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .header-left p.title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--accent-primary);
    margin-bottom: 0.75rem;
  }

  .web-summary {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
    max-width: 500px;
  }

  .header-right {
    flex: 0.8;
  }

  .contact-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
  }

  @media (min-width: 480px) and (max-width: 767px) {
    .contact-details {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: var(--text-secondary);
    min-width: 0;
  }

  .contact-item a {
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .contact-item svg {
    color: var(--accent-primary);
    flex-shrink: 0;
  }

  .contact-item a:hover {
    color: var(--accent-primary);
  }

  .contact-link-arrow {
    font-size: 0.75rem;
    margin-left: 0.15rem;
    opacity: 0.5;
    transition: opacity var(--transition-fast);
  }

  .contact-item a:hover .contact-link-arrow {
    opacity: 1;
  }

  /* Objective Section */
  .objective-section {
    margin-bottom: 2rem;
  }

  .objective-section h2 {
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .objective-text {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Experience Section Timeline */
  .experience-section {
    margin-bottom: 2rem;
  }

  .section-title-large {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .experience-timeline {
    border-left: 2px solid var(--timeline-line);
    padding-left: 1rem;
    margin-left: 0.5rem;
    display: flex;
    flex-direction: column;
    transition: border-color var(--transition-normal);
  }

  @media (min-width: 768px) {
    .experience-timeline {
      padding-left: 2rem;
      margin-left: 1rem;
    }
  }

  /* Education Section */
  .education-section h2 {
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .education-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .education-card {
    border-bottom: 1px solid var(--surface-border);
    padding-bottom: 1.5rem;
  }

  .education-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .education-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }

  @media (min-width: 640px) {
    .education-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .education-title-group {
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 640px) {
    .education-title-group {
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
  }

  .education-degree {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .education-institution {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent-primary);
  }

  .education-location {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .education-date {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    align-self: flex-start;
  }

  @media (min-width: 640px) {
    .education-date {
      align-self: auto;
    }
  }

  .education-field {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .education-details {
    list-style: none;
    padding-left: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .education-details li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .education-details li::before {
    content: "◦";
    position: absolute;
    left: 0;
    color: var(--accent-primary);
    font-weight: bold;
  }

  @media (max-width: 640px) {
    .header-left h1 {
      font-size: 1.8rem;
    }
    .header-left p.title {
      font-size: 1.05rem;
    }
    .contact-item {
      font-size: 0.8rem;
    }
  }
</style>
